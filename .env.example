# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# With password: postgresql://interviews:YOUR_PASSWORD@localhost:5432/winnow
# No password (local): postgresql://interviews@localhost:5432/winnow
DATABASE_URL=postgresql://interviews@localhost:5432/winnow

# API
PORT=3000

# HubSpot — Private App (legacy single-portal mode, used as fallback when no OAuth token is set)
HUBSPOT_ACCESS_TOKEN=your-private-app-token-here

# HubSpot — Public App OAuth (required for multi-tenant OAuth + CRM Card integration)
# Create a Public App at https://developers.hubspot.com/
# Set the redirect URI to: http://localhost:3000/api/hubspot/callback
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/hubspot/callback

# Anthropic (for AI Deal Summaries — Ticket 10)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
