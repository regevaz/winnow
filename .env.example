# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# With password: postgresql://interviews:YOUR_PASSWORD@localhost:5432/winnow
# No password (local): postgresql://interviews@localhost:5432/winnow
DATABASE_URL=postgresql://interviews@localhost:5432/winnow

# API
PORT=3000

# HubSpot
HUBSPOT_ACCESS_TOKEN=your-private-app-token-here

# Anthropic (for AI Deal Summaries — Ticket 10)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
